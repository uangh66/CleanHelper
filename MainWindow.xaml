<Window x:Class="CleanHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanHelper.ViewModels"
        Title="临时文件清理助手"
        Width="780" Height="800"
        MinWidth="640" MinHeight="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Microsoft YaHei UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主内容可滚动区域 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel>

                <!-- 标题 -->
                <TextBlock Text="临时文件清理助手"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8">
                    <Run Text="CleanHelper v1.0.0"/>
                    <Run Text=" · 个人电脑垃圾清理工具"/>
                </TextBlock>

                <!-- 工具按钮行 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                    <Button Content="关于与安全说明"
                            Command="{Binding AboutCommand}"
                            Height="28" Width="120"
                            FontSize="12"
                            Background="#E1E1E1"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="打开报告目录"
                            Command="{Binding OpenReportDirCommand}"
                            Height="28" Width="110"
                            FontSize="12"
                            Background="#E1E1E1"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- C盘空间信息卡片 -->
                <Border Background="{StaticResource CardBrush}"
                        CornerRadius="8" Padding="20,16"
                        Margin="0,0,0,14">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Opacity="0.08" BlurRadius="6"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="C 盘可用空间"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding AvailableSpace}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ========== TabControl ========== -->
                <TabControl Margin="0,0,0,14"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="#E1E1E1"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="20,10"/>
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#E1E1E1"
                                                BorderThickness="0,0,0,2"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="4,4,0,0">
                                            <ContentPresenter Content="{TemplateBinding Header}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- ================================================================ -->
                    <!-- 第一页：临时文件清理 -->
                    <!-- ================================================================ -->
                    <TabItem Header="临时文件清理">
                        <Border Background="White" Padding="20,16">
                            <StackPanel>

                                <!-- 扫描按钮 -->
                                <Button Content="扫描临时文件"
                                        Command="{Binding ScanCommand}"
                                        Height="42"
                                        FontSize="15" FontWeight="SemiBold"
                                        Background="{StaticResource PrimaryBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,0,14">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <!-- 文件列表 + 扫描结果卡片 -->
                                <Border Background="{StaticResource BgBrush}"
                                        CornerRadius="8" Padding="16,14"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="扫描结果"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,10"/>

                                        <!-- 扫描状态 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding ScanStatus}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                            <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                                         Margin="8,0,0,0"/>
                                        </StackPanel>

                                        <Separator Margin="0,0,0,8" Opacity="0.3"/>

                                        <!-- 操作按钮行 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="全选"
                                                    Command="{Binding SelectAllCommand}"
                                                    Height="28" Width="65"
                                                    FontSize="12"
                                                    Background="#E1E1E1"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Margin="0,0,6,0">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            <Button Content="取消全选"
                                                    Command="{Binding DeselectAllCommand}"
                                                    Height="28" Width="65"
                                                    FontSize="12"
                                                    Background="#E1E1E1"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Margin="0,0,6,0">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            <Button Content="仅勾选低风险"
                                                    Command="{Binding SelectLowRiskCommand}"
                                                    Height="28" Width="95"
                                                    FontSize="12"
                                                    Background="#E1E1E1"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Margin="0,0,10,0">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            <TextBlock Text="{Binding SelectedCountText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 数据表格 -->
                                        <DataGrid ItemsSource="{Binding FileList}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  MaxHeight="220"
                                                  Margin="0,0,0,8"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column"
                                                  Background="White"
                                                  BorderBrush="#E1E1E1"
                                                  BorderThickness="1"
                                                  RowHeight="28"
                                                  FontSize="12">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Padding" Value="6,0"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="36">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding CanClean}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="文件名" Width="*" Binding="{Binding FilePath}">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                            <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="大小" Width="75" Binding="{Binding SizeDisplay}">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="修改时间" Width="140"
                                                                    Binding="{Binding LastWriteTimeDisplay}"/>
                                                <DataGridTextColumn Header="风险" Width="60" Binding="{Binding RiskLevel}">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="ToolTip" Value="{Binding RiskReason}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RiskLevel}" Value="低风险">
                                                                    <Setter Property="Foreground" Value="#107C10"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RiskLevel}" Value="中风险">
                                                                    <Setter Property="Foreground" Value="#FF8C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RiskLevel}" Value="无法清理">
                                                                    <Setter Property="Foreground" Value="#D83B01"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <!-- 扫描统计 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="文件数量："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileCountText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="预计可清理："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EstimatedSizeText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="跳过文件："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SkippedCountText}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 清理按钮 -->
                                <Button Content="清理选中项"
                                        Command="{Binding CleanCommand}"
                                        Height="42"
                                        FontSize="15" FontWeight="SemiBold"
                                        Background="#D83B01"
                                        Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0,0,0,14">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <!-- 清理结果卡片 -->
                                <Border Background="{StaticResource BgBrush}"
                                        CornerRadius="8" Padding="16,14"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="清理结果"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="24"/>
                                                <RowDefinition Height="24"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="成功删除："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeletedCountText}"
                                                       Foreground="{StaticResource SuccessBrush}" FontSize="13"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="删除失败："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FailedCountText}"
                                                       Foreground="{StaticResource DangerBrush}" FontSize="13"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="成功处理大小："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SuccessSizeText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="真实释放空间："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActualSpaceFreedText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="C盘当前可用："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AvailableSpaceAfter}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontSize="13"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 导出报告 + 查看日志 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="导出报告"
                                            Command="{Binding ExportReportCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="查看日志"
                                            Command="{Binding ViewLogCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="#E1E1E1"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </TabItem>

                    <!-- ================================================================ -->
                    <!-- 第二页：空间体检 -->
                    <!-- ================================================================ -->
                    <TabItem Header="空间体检">
                        <Border Background="White" Padding="20,16">
                            <StackPanel>

                                <!-- 最小大小选择 -->
                                <Border Background="{StaticResource BgBrush}"
                                        CornerRadius="8" Padding="14,12"
                                        Margin="0,0,0,14">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="最小文件大小："
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding MinSizeOptions}"
                                                  SelectedItem="{Binding SelectedMinSizeMb}"
                                                  Width="80" Height="28"
                                                  FontSize="13"
                                                  VerticalContentAlignment="Center"/>
                                        <TextBlock Text="（仅显示大于此值的文件）"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 扫描 / 停止按钮 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="扫描大文件"
                                            Command="{Binding ScanLargeFilesCommand}"
                                            Height="38" Width="120"
                                            FontSize="14" FontWeight="SemiBold"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="停止扫描"
                                            Command="{Binding CancelLargeFileScanCommand}"
                                            Height="38" Width="100"
                                            FontSize="14"
                                            Background="#E1E1E1"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- 状态 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding LargeFileStatusText}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                 Visibility="{Binding IsLargeFileScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 Margin="8,0,0,0"/>
                                </StackPanel>

                                <!-- 大文件 DataGrid -->
                                <DataGrid ItemsSource="{Binding LargeFiles}"
                                          SelectedItem="{Binding SelectedLargeFile}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          MaxHeight="260"
                                          Margin="0,0,0,10"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          Background="White"
                                          BorderBrush="#E1E1E1"
                                          BorderThickness="1"
                                          RowHeight="28"
                                          FontSize="12">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Padding" Value="6,0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="文件名" Width="140" Binding="{Binding FileName}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding FileName}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="大小" Width="80" Binding="{Binding SizeDisplay}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="修改时间" Width="135"
                                                            Binding="{Binding LastWriteTimeDisplay}"/>
                                        <DataGridTextColumn Header="所属目录" Width="60" Binding="{Binding Category}"/>
                                        <DataGridTextColumn Header="类型" Width="55" Binding="{Binding Extension}"/>
                                        <DataGridTextColumn Header="建议说明" Width="*" Binding="{Binding Suggestion}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding Suggestion}"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Foreground" Value="#666666"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- 统计摘要 -->
                                <Border Background="{StaticResource BgBrush}"
                                        CornerRadius="8" Padding="14,12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="大文件数量："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LargeFileTotalCountText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="大文件总大小："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LargeFileTotalSizeText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="按目录汇总："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LargeFileCategorySummary}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="打开所在位置"
                                            Command="{Binding OpenLargeFileLocationCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="导出空间报告"
                                            Command="{Binding ExportSpaceReportCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </TabItem>
                    <!-- ================================================================ -->
                    <!-- 第三页：聊天缓存分析 -->
                    <!-- ================================================================ -->
                    <TabItem Header="聊天缓存分析">
                        <Border Background="White" Padding="20,16">
                            <StackPanel>

                                <!-- 扫描 / 停止按钮 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="扫描聊天缓存"
                                            Command="{Binding ScanChatCachesCommand}"
                                            Height="38" Width="140"
                                            FontSize="14" FontWeight="SemiBold"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="停止扫描"
                                            Command="{Binding CancelChatCacheScanCommand}"
                                            Height="38" Width="100"
                                            FontSize="14"
                                            Background="#E1E1E1"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- 状态 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding ChatCacheStatusText}"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                 Visibility="{Binding IsChatCacheScanning, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 Margin="8,0,0,0"/>
                                </StackPanel>

                                <!-- 说明文字 -->
                                <TextBlock Text="扫描当前用户微信、QQ、企业微信、钉钉的缓存目录占用情况（仅统计，不删除）"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <!-- 结果 DataGrid -->
                                <DataGrid ItemsSource="{Binding ChatCaches}"
                                          SelectedItem="{Binding SelectedChatCache}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          MaxHeight="280"
                                          Margin="0,0,0,10"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          Background="White"
                                          BorderBrush="#E1E1E1"
                                          BorderThickness="1"
                                          RowHeight="28"
                                          FontSize="12">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="软件" Width="60" Binding="{Binding SoftwareName}"/>
                                        <DataGridTextColumn Header="目录类型" Width="110" Binding="{Binding DirectoryType}"/>
                                        <DataGridTextColumn Header="是否存在" Width="65" Binding="{Binding ExistsDisplay}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExistsDisplay}" Value="存在">
                                                            <Setter Property="Foreground" Value="#107C10"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ExistsDisplay}" Value="未发现">
                                                            <Setter Property="Foreground" Value="#999999"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="大小" Width="75" Binding="{Binding SizeDisplay}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="文件数" Width="65" Binding="{Binding FileCountDisplay}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="修改时间" Width="135"
                                                            Binding="{Binding LastWriteTimeDisplay}"/>
                                        <DataGridTextColumn Header="建议说明" Width="*" Binding="{Binding Suggestion}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding Suggestion}"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- 统计摘要 -->
                                <Border Background="{StaticResource BgBrush}"
                                        CornerRadius="8" Padding="14,12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="22"/>
                                                <RowDefinition Height="22"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="发现目录："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChatCacheDirCountText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="总占用大小："
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ChatCacheTotalSizeText}"
                                                       Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="打开目录"
                                            Command="{Binding OpenChatCacheLocationCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="导出缓存报告"
                                            Command="{Binding ExportChatCacheReportCommand}"
                                            Height="36" Width="110"
                                            FontSize="13"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                Padding="16,8"
                BorderBrush="#E1E1E1" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusBarText}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
